<!DOCTYPE html>
<html lang="en">

<head>
       <meta charset="UTF-8">
       <meta name="viewport" content="width=device-width, initial-scale=1.0">
       <title>AI Prompts for Gemini & ChatGPT | PromptLiko</title>

       <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

       <link rel="preconnect" href="https://fonts.googleapis.com">
       <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
       <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,500;9..144,600&family=Inter:wght@400;500&family=IBM+Plex+Mono:wght@400;500&display=swap"
              rel="stylesheet">

       <style>
              :root {
                     --void: #0a0a0b;
                     --surface: #141416;
                     --hairline: #27272b;
                     --ivory: #eeeae1;
                     --muted: #9a9589;
                     --accent: #c69a5c;
                     --accent-dim: #8a6b3f;
              }

              * {
                     box-sizing: border-box;
              }

              body {
                     background-color: var(--void);
                     color: var(--ivory);
                     font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
              }

              .font-display {
                     font-family: 'Fraunces', ui-serif, Georgia, serif;
                     font-optical-sizing: auto;
              }

              .font-mono {
                     font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, monospace;
              }

              .bg-void {
                     background-color: var(--void);
              }

              .bg-surface {
                     background-color: var(--surface);
              }

              .border-hairline {
                     border-color: var(--hairline);
              }

              .text-ivory {
                     color: var(--ivory);
              }

              .text-muted {
                     color: var(--muted);
              }

              .text-accent {
                     color: var(--accent);
              }

              .border-accent {
                     border-color: var(--accent);
              }

              .grain {
                     position: fixed;
                     inset: 0;
                     pointer-events: none;
                     z-index: 40;
                     background:
                            radial-gradient(ellipse at 50% 0%, rgba(198, 154, 92, 0.05), transparent 60%),
                            radial-gradient(ellipse at 50% 100%, rgba(0, 0, 0, 0.5), transparent 55%);
              }

              .card {
                     transition: border-color 220ms ease, transform 220ms ease;
              }

              .card:hover {
                     border-color: var(--accent);
              }

              .card:hover .card-img {
                     transform: scale(1.04);
              }

              .card-img {
                     transition: transform 500ms ease;
              }

              .frame-tick {
                     opacity: 0;
                     transition: opacity 220ms ease;
              }

              .card:hover .frame-tick {
                     opacity: 1;
              }

              a:focus-visible,
              button:focus-visible {
                     outline: 2px solid var(--accent);
                     outline-offset: 2px;
              }

              @media (prefers-reduced-motion: reduce) {

                     .card,
                     .card-img,
                     .frame-tick {
                            transition: none;
                     }
              }
       </style>
</head>

<body class="antialiased">

       <div class="grain"></div>

       <div class="min-h-screen flex flex-col">

              <!-- Header -->
              <header class="border-b border-hairline px-6 md:px-10 py-5 flex items-center justify-between">
                     <span class="font-mono text-[11px] tracking-[0.3em] uppercase text-muted">PromptLiko</span>
                     <span
                            class="font-mono text-[11px] tracking-[0.3em] uppercase text-accent">AI&nbsp;—&nbsp;Generated</span>
              </header>

              <main class="flex-1 max-w-7xl w-full mx-auto px-6 md:px-10 py-12 md:py-16">

                     <div class="mb-12 md:mb-16 max-w-2xl">
                            <p class="font-mono text-[11px] tracking-[0.3em] uppercase text-accent mb-4">
                                   Prompt&nbsp;Archive
                            </p>
                            <h1 class="font-display font-medium text-4xl md:text-5xl leading-[1.08] text-balance">
                                   Latest AI Prompts
                            </h1>
                            <p class="text-muted leading-relaxed mt-4 text-[15px] md:text-base">
                                   Portraits and scenes generated for Gemini and ChatGPT, with the exact prompt behind
                                   each one.
                            </p>
                     </div>

                     <% if (images.length===0) { %>

                            <div class="border border-hairline bg-surface py-24 px-6 text-center">
                                   <p class="font-mono text-[11px] tracking-[0.3em] uppercase text-muted mb-3">
                                          Archive&nbsp;Empty</p>
                                   <p class="font-display text-2xl text-ivory/80">No prompts uploaded yet.</p>
                            </div>

                            <% } else { %>

                                   <div class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">

                                          <% images.forEach((image, i)=> { %>

                                                 <a href="/image/<%= image.slug %>"
                                                        class="card group relative block border border-hairline bg-surface">
                                                        <span
                                                               class="frame-tick absolute top-2 left-2 w-4 h-4 border-t border-l border-accent z-10"></span>
                                                        <span
                                                               class="frame-tick absolute top-2 right-2 w-4 h-4 border-t border-r border-accent z-10"></span>
                                                        <span
                                                               class="frame-tick absolute bottom-2 left-2 w-4 h-4 border-b border-l border-accent z-10"></span>
                                                        <span
                                                               class="frame-tick absolute bottom-2 right-2 w-4 h-4 border-b border-r border-accent z-10"></span>

                                                        <div class="relative overflow-hidden">
                                                               <img src="<%= image.image.url %>"
                                                                      class="card-img w-full h-64 object-top object-cover"
                                                                      alt="<%= image.seo.alt %>" loading="lazy">
                                                               <span
                                                                      class="absolute bottom-3 left-3 font-mono text-[10px] tracking-widest text-ivory/80 bg-black/55 backdrop-blur px-2 py-1">
                                                                      <%= String(i + 1).padStart(3, '0' ) %>
                                                               </span>
                                                        </div>

                                                        <div class="p-5">

                                                               <h2
                                                                      class="font-display text-lg leading-snug line-clamp-2 text-ivory">
                                                                      <%= image.title %>
                                                               </h2>

                                                               <p
                                                                      class="font-mono text-[10px] tracking-[0.2em] uppercase text-accent mt-3">
                                                                      <%= image.category.name %>
                                                               </p>

                                                               <div
                                                                      class="mt-5 pt-4 border-t border-hairline flex items-center justify-between font-mono text-[11px] tracking-wide text-muted">

                                                                      <span class="flex items-center gap-1.5">
                                                                             <svg width="13" height="13"
                                                                                    viewBox="0 0 24 24" fill="none"
                                                                                    stroke="currentColor"
                                                                                    stroke-width="2"
                                                                                    stroke-linecap="round"
                                                                                    stroke-linejoin="round">
                                                                                    <path
                                                                                           d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8Z">
                                                                                    </path>
                                                                                    <circle cx="12" cy="12" r="3">
                                                                                    </circle>
                                                                             </svg>
                                                                             <%= image.stats.views %>
                                                                      </span>

                                                                      <span class="flex items-center gap-1.5">
                                                                             <svg width="13" height="13"
                                                                                    viewBox="0 0 24 24" fill="none"
                                                                                    stroke="currentColor"
                                                                                    stroke-width="2"
                                                                                    stroke-linecap="round"
                                                                                    stroke-linejoin="round">
                                                                                    <rect x="9" y="9" width="13"
                                                                                           height="13" rx="2"></rect>
                                                                                    <path
                                                                                           d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1">
                                                                                    </path>
                                                                             </svg>
                                                                             <%= image.stats.promptCopies %>
                                                                      </span>

                                                               </div>

                                                        </div>

                                                 </a>

                                                 <% }) %>

                                   </div>

                                   <% } %>

              </main>

              <footer class="border-t border-hairline px-6 md:px-10 py-5 text-center">
                     <span class="font-mono text-[10px] tracking-widest text-muted uppercase">
                            Generated with artificial intelligence
                     </span>
              </footer>

       </div>

</body>

</html>