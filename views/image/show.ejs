<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        <%= image.seo.title || image.title %>
    </title>

    <meta name="description" content="<%= image.seo.description %>">

    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,500;9..144,600&family=Inter:wght@400;500&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">

    <style>
        :root {
            --void: #0a0a0b;
            --surface: #141416;
            --hairline: #27272b;
            --ivory: #eeeae1;
            --muted: #9a9589;
            --accent: #c69a5c;
            --accent-dim: #8a6b3f;
        }

        * {
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--void);
            color: var(--ivory);
            font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;
        }

        .font-display {
            font-family: 'Fraunces', ui-serif, Georgia, serif;
            font-optical-sizing: auto;
        }

        .font-mono {
            font-family: 'IBM Plex Mono', ui-monospace, SFMono-Regular, monospace;
        }

        .bg-void { background-color: var(--void); }
        .bg-surface { background-color: var(--surface); }
        .border-hairline { border-color: var(--hairline); }
        .text-ivory { color: var(--ivory); }
        .text-muted { color: var(--muted); }
        .text-accent { color: var(--accent); }
        .bg-accent { background-color: var(--accent); }
        .border-accent { border-color: var(--accent); }

        /* subtle film grain / vignette, purely decorative */
        .grain {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 40;
            background:
                radial-gradient(ellipse at 50% 0%, rgba(198, 154, 92, 0.06), transparent 60%),
                radial-gradient(ellipse at 50% 100%, rgba(0, 0, 0, 0.5), transparent 55%);
        }

        textarea::-webkit-scrollbar { width: 8px; }
        textarea::-webkit-scrollbar-track { background: transparent; }
        textarea::-webkit-scrollbar-thumb { background: var(--hairline); border-radius: 4px; }

        button:focus-visible,
        textarea:focus-visible {
            outline: 2px solid var(--accent);
            outline-offset: 2px;
        }

        .copy-btn {
            transition: border-color 160ms ease, color 160ms ease, background-color 160ms ease;
        }

        .frame-tick {
            transition: opacity 300ms ease;
        }

        @media (prefers-reduced-motion: reduce) {
            html { scroll-behavior: auto; }
            .copy-btn, .frame-tick { transition: none; }
        }
    </style>

</head>

<body class="antialiased">

    <div class="grain"></div>

    <div class="min-h-screen flex flex-col">

        <!-- Header -->
        <header class="border-b border-hairline px-6 md:px-10 py-5 flex items-center justify-between">
            <span class="font-mono text-[11px] tracking-[0.3em] uppercase text-muted">Prompt&nbsp;Archive</span>
            <span class="font-mono text-[11px] tracking-[0.3em] uppercase text-accent">AI&nbsp;—&nbsp;Generated</span>
        </header>

        <!-- Main -->
        <main class="flex-1 grid lg:grid-cols-[1.05fr_1fr]">

            <!-- Image column -->
            <div class="relative border-b lg:border-b-0 lg:border-r border-hairline bg-surface">
                <div class="lg:sticky lg:top-0 lg:h-screen flex items-center justify-center p-6 sm:p-10">
                    <div class="relative w-full max-w-md">

                        <img
                            src="<%= image.image.url %>"
                            alt="<%= image.title %>"
                            class="w-full aspect-[3/4] object-cover shadow-2xl shadow-black/70"
                        >

                        <!-- corner frame ticks -->
                        <span class="frame-tick absolute -top-2.5 -left-2.5 w-5 h-5 border-t border-l border-accent/70"></span>
                        <span class="frame-tick absolute -top-2.5 -right-2.5 w-5 h-5 border-t border-r border-accent/70"></span>
                        <span class="frame-tick absolute -bottom-2.5 -left-2.5 w-5 h-5 border-b border-l border-accent/70"></span>
                        <span class="frame-tick absolute -bottom-2.5 -right-2.5 w-5 h-5 border-b border-r border-accent/70"></span>

                        <div class="absolute bottom-3 left-3 font-mono text-[10px] tracking-widest text-ivory/80 bg-black/55 backdrop-blur px-2 py-1">
                            FRAME&nbsp;001
                        </div>
                    </div>
                </div>
            </div>

            <!-- Content column -->
            <div class="px-6 sm:px-10 lg:px-14 py-10 lg:py-16 w-full max-w-2xl">

                <p class="font-mono text-[11px] tracking-[0.3em] uppercase text-accent mb-4">
                    Generated&nbsp;Portrait
                </p>

                <h1 class="font-display font-medium text-4xl md:text-5xl leading-[1.08] mb-6 text-balance">
                    <%= image.title %>
                </h1>

                <p class="text-muted leading-relaxed text-[15px] md:text-base mb-10 max-w-xl">
                    <%= image.description %>
                </p>

                <section>
                    <div class="flex items-center justify-between mb-3">
                        <h2 class="font-mono text-[11px] tracking-[0.3em] uppercase text-ivory/80">
                            Prompt
                        </h2>

                        <button
                            id="copyBtn"
                            class="copy-btn flex items-center gap-2 border border-hairline hover:border-accent text-ivory/90 hover:text-accent text-[12px] font-mono tracking-wide uppercase px-4 py-2"
                        >
                            <svg id="copyIcon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect x="9" y="9" width="13" height="13" rx="2"></rect>
                                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                            </svg>
                            <span id="copyLabel">Copy</span>
                        </button>
                    </div>

                    <div class="border border-hairline bg-surface">
                        <div class="flex items-center justify-between px-4 py-2 border-b border-hairline">
                            <span class="font-mono text-[10px] tracking-widest text-muted">PROMPT.TXT</span>
                            <span id="charCount" class="font-mono text-[10px] tracking-widest text-muted"></span>
                        </div>

                        <textarea
                            id="promptText"
                            readonly
                            class="w-full h-56 md:h-64 bg-transparent p-4 font-mono text-[13px] leading-relaxed text-ivory/90 resize-none focus:outline-none"
                        ><%= image.prompt %></textarea>
                    </div>
                </section>

            </div>

        </main>

        <!-- Footer -->
        <footer class="border-t border-hairline px-6 md:px-10 py-5 text-center">
            <span class="font-mono text-[10px] tracking-widest text-muted uppercase">
                Generated with artificial intelligence
            </span>
        </footer>

    </div>

    <script>
        const btn = document.getElementById("copyBtn");
        const icon = document.getElementById("copyIcon");
        const label = document.getElementById("copyLabel");
        const promptField = document.getElementById("promptText");
        const charCount = document.getElementById("charCount");

        const checkIcon = `<path d="M20 6 9 17l-5-5"></path>`;
        const copyIconPath = `<rect x="9" y="9" width="13" height="13" rx="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>`;

        function updateCharCount() {
            const len = promptField.value.trim().length;
            charCount.textContent = len + " CHARS";
        }
        updateCharCount();

        btn.addEventListener("click", async () => {
            try {
                await navigator.clipboard.writeText(promptField.value);
            } catch (err) {
                promptField.select();
                document.execCommand("copy");
            }

            icon.innerHTML = checkIcon;
            label.textContent = "Copied";
            btn.classList.add("border-accent", "text-accent");

            setTimeout(() => {
                icon.innerHTML = copyIconPath;
                label.textContent = "Copy";
                btn.classList.remove("border-accent", "text-accent");
            }, 2000);
        });
    </script>

</body>

</html>